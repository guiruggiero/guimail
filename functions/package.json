{
  "name": "functions",
  "description": "Cloud Functions for Firebase",
  "type": "module",
  "engines": {
    "node": "22"
  },
  "private": true,
  "main": "index.js",
  "dependencies": {
    "@google/genai": "^1.48.0",
    "@langfuse/client": "^5.1.0",
    "@sentry/node": "^10.48.0",
    "axios": "^1.13.5",
    "axios-retry": "^4.5.0",
    "firebase-functions": "^7.1.1",
    "googleapis": "^171.0.0",
    "marked": "^13.0.3",
    "nodemailer": "^8.0.4",
    "postal-mime": "^2.7.1",
    "remove-markdown": "^0.6.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "eslint-config-google": "^0.14.0",
    "express": "^5.2.1",
    "firebase-tools": "^15.14.0",
    "globals": "^17.5.0",
    "helmet": "^8.1.0"
  },
  "scripts": {
    "lint": "eslint .",
    "lint-fix": "eslint . --fix",
    "deploy": "npx firebase deploy --only functions:guimail",
    "prompt-pull": "node --env-file=.env scripts/prompt.js pull",
    "prompt-push": "node --env-file=.env scripts/prompt.js push",
    "friends": "node scripts/friends.js",
    "start": "node --env-file=.env scripts/claudeCodeGateway.js",
    "pm2": "pm2 restart claudeCodeGateway",
    "pm2-config": "pm2 stop all && pm2 delete claudeCodeGateway && pm2 start scripts/pm2.config.js && pm2 save"
  }
